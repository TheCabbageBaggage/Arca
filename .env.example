# Security
JWT_SECRET=replace-with-256-bit-random-secret
JWT_EXPIRES_IN=8h
AGENT_KEY_SECRET=replace-with-separate-secret

# API
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# SQLite
DATABASE_PATH=/data/sqlite/arca.db

# LLM Providers (optional for M1)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434
LM_STUDIO_BASE_URL=http://host.docker.internal:1234

# LLM Defaults
LLM_DEFAULT_PROVIDER=anthropic
LLM_DEFAULT_MODEL=claude-sonnet-4-20250514
LLM_FALLBACK_PROVIDER=ollama
LLM_FALLBACK_MODEL=llama3.1
LLM_CONFIDENTIAL_PROVIDER=ollama
LLM_COST_THRESHOLD_USD=0.50

# Token Budget
TOKEN_SPRINT_BUDGET=2400000
TOKEN_TASK_MAX=500000
TOKEN_WARN_THRESHOLD=0.85

# Nextcloud (optional for M1)
NEXTCLOUD_URL=
NEXTCLOUD_USER=
NEXTCLOUD_PASSWORD=
NEXTCLOUD_BASE_PATH=/ERP-Documents

# Company
COMPANY_NAME=Example Company
COMPANY_TAX_ID=US-EIN-00-0000000
FISCAL_YEAR_START=01-01
BASE_CURRENCY=USD

# Backup
BACKUP_RETENTION_DAYS=30
